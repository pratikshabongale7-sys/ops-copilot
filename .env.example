# Copy this file to ".env" and fill in your real values.
# .env is gitignored so your keys never get committed.

# --- LangSmith (tracing/observability) ---
LANGSMITH_TRACING=true
# Use the EU endpoint if you signed up in the EU region:
#   https://eu.api.smith.langchain.com   (otherwise use the US one below)
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=lsv2_your_key_here
LANGSMITH_PROJECT=ops-copilot

# --- LLM for the agent (Phase 3) ---
# Provider: groq (free, default) | openai | google
LLM_PROVIDER=groq
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
# How many reason->act steps the agent may take before it must conclude.
AGENT_STEP_BUDGET=12

# If LLM_PROVIDER=openai  -> set OPENAI_API_KEY (and optionally OPENAI_MODEL)
# If LLM_PROVIDER=google  -> set GOOGLE_API_KEY (and optionally GOOGLE_MODEL)
